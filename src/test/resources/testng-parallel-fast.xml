<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
FAST PARALLEL CONFIGURATION
Use this for maximum parallelization with 5 threads
Ideal for: CI/CD pipelines with sufficient resources
Performance: ~10-15 seconds for 3 tests
Resource Usage: High (5 concurrent browser instances)
-->
<suite name="Practice Software Testing Suite - Fast Parallel" parallel="methods" thread-count="5" verbose="2">
    <parameter name="browser" value="chrome"/>

    <!-- Listeners for reporting -->
    <listeners>
        <listener class-name="com.automation.listeners.ExtentReportsListener"/>
    </listeners>

    <test name="Search Tests - Fast Parallel">
        <classes>
            <class name="com.automation.tests.SearchTest">
                <methods>
                    <include name="testSearchHammerAndVerifyProductTitle"/>
                    <include name="testAddToCartButtonIsVisible"/>
                    <include name="testVerifyProductPrice"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

